<Project Sdk="Dalamud.NET.Sdk/15.0.0">
  <PropertyGroup>
    <Version>0.4.0.0</Version>
    <Description>A timestamped log of furniture placed and removed in your house.</Description>
    <PackageLicenseExpression>AGPL-3.0-or-later</PackageLicenseExpression>
    <IsPackable>false</IsPackable>

    <!-- We poke the game's housing structs directly, so unsafe is required.
         (The Dalamud SDK usually enables this already; set explicitly to be safe.) -->
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>
</Project>
